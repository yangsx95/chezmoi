[data]
    name = "杨顺翔"
    email = "yangsx95@qq.com"
    maven_repo_dir = ".m2/repository"

    # 勿在此填写真实令牌；在本地 ~/.config/chezmoi/chezmoi.toml 的 [data] 中设置，或设置环境变量 GITHUB_TOKEN
    github_api_token = ""

    # Proxy configuration
    proxy_url = "http://127.0.0.1:7890"

    # Windows PowerShell：mise 数据目录；若环境变量 MISE_DATA_DIR 已设置则优先生效
    mise_data_dir = "D:/mise"

    # Windows：Anaconda 安装目录（与 setup.ps1 / winget 静默安装一致）及 conda 包缓存、环境目录（写入 ~/.condarc）
    conda_root = "D:/Anaconda3"
    conda_pkgs_dir = "D:/conda/pkgs"
    conda_envs_dir = "D:/conda/envs"
