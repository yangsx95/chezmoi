# =============================================================================
# Mise 全局配置文件
# =============================================================================

[settings]
# 保留下载的安装包（false 表示安装后自动删除，节省磁盘空间）
always_keep_download = false

# 启用实验性功能（包括目录自动切换版本等）
experimental = true

# 生成 mise.lock 文件，锁定精确版本
lockfile = true


# =============================================================================
# 全局工具版本
# 数组表示安装多个版本，默认激活数组中最后一个
# =============================================================================
[tools]

# Java
java = ["zulu-8", "zulu-17", "zulu-21"]
maven  = "latest"
gradle = "latest"

# Python
python = ["latest"]

# uv - Python 包管理/venv 工具
uv = "latest"

# Go
go = "latest"

# Node.js
node = ["20", "22"]


# =============================================================================
# 全局环境变量
# 对所有项目生效（本地项目配置可覆盖）
# =============================================================================
[env]
# Maven JVM 内存设置
MAVEN_OPTS = "-Xmx2g"

# Gradle JVM 参数设置
GRADLE_OPTS = "-Dorg.gradle.jvmargs='-Xmx2g -XX:MaxMetaspaceSize=512m'"

# Go 模块下载代理（国内加速）
GOPROXY = "https://goproxy.cn,direct"

# 私有仓库跳过代理（示例，实际使用时修改域名）
# GOPRIVATE = "git.example.com,*.internal.com"
