{
  "log": {
    "level": "info",
    "timestamp": true
  },
  "inbounds": [
    {
      "type": "mixed",
      "tag": "mixed-in",
      "listen": "127.0.0.1",
      "listen_port": 7890,
      "set_system_proxy": false
    }
  ],
  "outbounds": [
    {
      "type": "direct",
      "tag": "direct"
    },
    {
      "type": "block",
      "tag": "block"
    }
  ],
  "route": {
    "rules": [
      {
        "domain": [
          "analytics.google.com",
          "www.google-analytics.com"
        ],
        "outbound": "block"
      },
      {
        "domain_suffix": [
          "doubleclick.net",
          "googleadservices.com",
          "googlesyndication.com",
          "googletagmanager.com",
          "googletagservices.com",
          "scorecardresearch.com",
          "umeng.com"
        ],
        "outbound": "block"
      }
    ],
    "final": "direct"
  }
}
