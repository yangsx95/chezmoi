# PowerShell 通用配置文件 (.profile.ps1)
# 被 Microsoft.PowerShell_profile.ps1 引用

# 设置 mise 安装路径
$env:MISE_DATA_DIR = "D:\mise"

# Add mise to PATH environment variable
if (-not $env:PATH.Contains("$env:MISE_DATA_DIR\shims")) {
    $env:PATH = "$env:MISE_DATA_DIR\shims;$env:PATH"
}

# Ensure mise uses the correct data directory
if (-not $env:MISE_CACHE_DIR) {
    $env:MISE_CACHE_DIR = "$env:MISE_DATA_DIR\cache"
}

# Add Python Scripts directory to PATH
# 检查当前激活的 Python 版本
if (Test-Path "$env:MISE_DATA_DIR\installs\python") {
    $pythonVersions = Get-ChildItem "$env:MISE_DATA_DIR\installs\python" -Directory | Select-Object -ExpandProperty Name
    foreach ($version in $pythonVersions) {
        $scriptsDir = "$env:MISE_DATA_DIR\installs\python\$version\Scripts"
        if ((Test-Path $scriptsDir) -and (-not $env:PATH.Contains($scriptsDir))) {
            $env:PATH = "$scriptsDir;$env:PATH"
        }
    }
}
